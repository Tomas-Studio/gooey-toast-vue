{
  "name": "gooey-toast-vue",
  "version": "0.2.2",
  "description": "A gooey, morphing toast notification library for Vue, powered by motion-v and vue-sonner",
  "type": "module",
  "license": "MIT",
  "author": "olakunle.olatunji",
  "repository": {
    "type": "git",
    "url": "https://github.com/Tomas-Studio/gooey-toast-vue.git"
  },
  "homepage": "https://github.com/Tomas-Studio/gooey-toast-vue#readme",
  "bugs": {
    "url": "https://github.com/Tomas-Studio/gooey-toast-vue/issues"
  },
  "main": "./dist/gooey-toast-vue.cjs",
  "module": "./dist/gooey-toast-vue.mjs",
  "types": "./dist/types/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/src/index.d.ts",
      "import": "./dist/gooey-toast-vue.mjs",
      "require": "./dist/gooey-toast-vue.cjs"
    },
    "./style.css": "./dist/gooey-toast-vue.css",
    "./nuxt": "./src/nuxt.ts"
  },
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "dist",
    "src/nuxt.ts",
    "src/runtime"
  ],
  "keywords": [
    "vue",
    "vue3",
    "toast",
    "notification",
    "sonner",
    "motion",
    "animation",
    "morph",
    "gooey",
    "blob",
    "spring",
    "nuxt",
    "nuxt-module"
  ],
  "scripts": {
    "dev": "npm run --prefix demo dev",
    "dev:lib": "vite build --watch",
    "build": "vue-tsc -b && vite build",
    "build:demo": "npm run --prefix demo build",
    "preview": "npm run --prefix demo preview",
    "typecheck": "vue-tsc --noEmit",
    "prepublishOnly": "npm run build",
    "bump": "npx changeset",
    "version": "changeset version",
    "release": "changeset publish"
  },
  "peerDependencies": {
    "vue": ">=3.3.0"
  },
  "dependencies": {
    "motion": "^12.38.0",
    "motion-v": "^2.2.0",
    "vue-sonner": "^2.0.9"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@nuxt/kit": "^4.0.0",
    "@nuxt/schema": "^4.4.2",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "vite-plugin-dts": "^4.5.4",
    "vue": "^3.5.32",
    "vue-tsc": "^3.2.6"
  }
}
